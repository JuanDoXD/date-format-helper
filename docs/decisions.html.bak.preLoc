      <!-- Futuro Mañana -->
      <div class="cap-card" data-level="futuro-man">
        <div class="cover">
          <div class="level-tag">Futuro Mañana</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"></span><span class="tk tk-date">Mañana<span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""></span><span class="tk tk-date">Amanhã<span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></span></span>
              <span class="loc-text" data-locale="de-DE" hidden=""></span><span class="tk tk-date">Morgen<span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></span></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Futuro 2-7 días -->
      <div class="cap-card" data-level="futuro-2-7d">
        <div class="cover">
          <div class="level-tag">Futuro 2-7 días</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"></span><span class="tk tk-date">Mié. 1</span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""></span><span class="tk tk-date">Qua, 1</span></span>
              <span class="loc-text" data-locale="de-DE" hidden=""></span><span class="tk tk-date">Mi., 1.</span></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Futuro +7 días -->
      <div class="cap-card" data-level="futuro-7d">
        <div class="cover">
          <div class="level-tag">Futuro +7 días</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"></span><span class="tk tk-date">6 jul.</span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""></span><span class="tk tk-date">6 jul.</span></span>
