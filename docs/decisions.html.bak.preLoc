        <div class="cover" style="background-image:url(&#39;img/mockup-cover-live.png&#39;)">
          <div class="level-tag">Directo</div>
        </div>
      </div>

      <!-- Futuro Hoy -->
      <div class="cap-card" data-level="futuro-hoy">
        <div class="cover">
          <div class="level-tag">Futuro Hoy</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"></span><span class="tk tk-date">Hoy<span class="tk tk-comma">,</span> <span class="tk tk-time">22:30</span></span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""></span><span class="tk tk-date">Hoje<span class="tk tk-comma">,</span> <span class="tk tk-time">22:30</span></span></span>
              <span class="loc-text" data-locale="de-DE" hidden=""></span><span class="tk tk-date">Heute<span class="tk tk-comma">,</span> <span class="tk tk-time">22:30</span></span></span>
            </span>
