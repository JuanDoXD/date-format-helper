<!-- ===================== CONTEXTOS ===================== -->
<section class="block" id="contextos">
  <h2><span class="num">02</span><i class="ph ph-frame-corners"></i>Contextos</h2>
  <p class="desc">Ejemplos visuales de Airing aplicado en cada sección real del servicio.</p>

  <!-- Caption en contexto · cards reales -->
  <div class="caption-context-wrap" data-active-locale="es-ES">
    <h3><i class="ph ph-cards"></i> Caption en contexto · cards reales</h3>
    <p class="sub">Columna aplicada: <strong>Caption</strong>. Proporciones reales del servicio. Cards usan <code>img/mockup-cover-base.png</code> como base. Respeta los selectores Locale y Render (Figma / Tokens).</p>

    <div class="caption-context">

      <!-- Pasado +1 año -->
      <div class="cap-card" data-level="pasado-1ano">
        <div class="cover">
          <div class="level-tag">Pasado +1 año</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">26/06/25</span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""><span class="tk tk-prefix">Exibido</span> <span class="tk tk-date">26/06/25</span></span>
              <span class="loc-text" data-locale="de-DE" hidden=""><span class="tk tk-date">26.06.25</span> <span class="tk tk-prefix">gesendet</span></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Pasado +7 días -->
      <div class="cap-card" data-level="pasado-7d">
        <div class="cover">
          <div class="level-tag">Pasado +7 días</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">16 jun.</span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""><span class="tk tk-prefix">Exibido</span> <span class="tk tk-date">16 jun.</span></span>
              <span class="loc-text" data-locale="de-DE" hidden=""><span class="tk tk-date">16. Jun.</span> <span class="tk tk-prefix">gesendet</span></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Pasado 2-7 días -->
      <div class="cap-card" data-level="pasado-2-7d">
        <div class="cover">
          <div class="level-tag">Pasado 2-7 días</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"><img class="tk-u7d" src="img/U7D.png" alt="U7D"> <span class="tk tk-date">dom. 21</span></span>
              <span class="loc-text" data-locale="es-HISPAM" hidden=""></span><span class="tk tk-prefix">Emitido <span class="tk tk-date">dom. 21</span></span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""></span><span class="tk tk-prefix">Exibido <span class="tk tk-date">dom, 21</span></span></span>
              <span class="loc-text" data-locale="de-DE" hidden=""></span><span class="tk tk-date">So., 21. <span class="tk tk-prefix">gesendet</span></span></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Pasado Ayer -->
      <div class="cap-card" data-level="pasado-ayer">
        <div class="cover">
          <div class="level-tag">Pasado Ayer</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"><img class="tk-u7d" src="img/U7D.png" alt="U7D"> <span class="tk tk-date">ayer</span></span>
              <span class="loc-text" data-locale="es-HISPAM" hidden=""></span><span class="tk tk-prefix">Emitido <span class="tk tk-date">ayer</span></span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""></span><span class="tk tk-prefix">Exibido <span class="tk tk-date">ontem</span></span></span>
              <span class="loc-text" data-locale="de-DE" hidden=""></span><span class="tk tk-date">Gestern <span class="tk tk-prefix">gesendet</span></span></span>
            </span>
          </div>
        </div>
      </div>

      <!-- Pasado Hoy -->
      <div class="cap-card" data-level="pasado-hoy">
        <div class="cover">
          <div class="level-tag">Pasado Hoy</div>
          <div class="caption-row">
            <span class="caption-content">
              <span class="loc-text" data-locale="es-ES"></span><img class="tk-u7d" src="img/U7D.png" alt="U7D"> <span class="tk tk-date">hoy</span></span>
              <span class="loc-text" data-locale="es-HISPAM" hidden=""></span><span class="tk tk-prefix">Emitido <span class="tk tk-date">hoy</span></span></span>
              <span class="loc-text" data-locale="pt-BR" hidden=""></span><span class="tk tk-prefix">Exibido <span class="tk tk-date">hoje</span></span></span>
              <span class="loc-text" data-locale="de-DE" hidden=""></span><span class="tk tk-date">Heute <span class="tk tk-prefix">gesendet</span></span></span>
            </span>
          </div>
        </div>
