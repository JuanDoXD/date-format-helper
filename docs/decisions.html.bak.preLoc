    </div>
  </div>

  <!-- Content info -->
  <div class="ctx-block" data-context="content-info" data-active-device="tv-core" data-active-locale="es-ES">
    <h3><i class="ph ph-identification-card"></i> Content info · línea de metadatos</h3>
    <p class="sub">Columna aplicada: <strong>Airing · Default inline</strong>, al final de la línea de metadatos (tras el género). Usa el toggle para alternar dispositivo. Cada dispositivo trae su <strong>mockup reference</strong> (con airing) y una <strong>base limpia</strong> (sin airing) como canvas para los casos.</p>

    <div class="device-tabs" role="tablist" aria-label="Dispositivo">
      <button class="device-tab active" data-device="tv-core" type="button"><i class="ph ph-television-simple"></i>TV (CORE)</button>
      <button class="device-tab" data-device="web" type="button"><i class="ph ph-monitor"></i>Web</button>
    </div>

    <!-- TV (CORE) -->
    <div class="device-panel" data-device="tv-core">
      <div class="ctx-col">
        <div class="col-label"><i class="ph ph-squares-four"></i>Ejemplos dinámicos · Airing · Default inline</div>
        <div class="ci-cases ci-cases-tv" style="--ax:44%;--ay:75.9%;--asz:13px;--acol:#acacac">
