<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<title>Date format · Movistar+</title>
<link rel="preconnect" href="https://unpkg.com" crossorigin>
<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css">
<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/fill/style.css">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700&display=swap">
<style>
:root {
  --bg: #fafafa;
  --bg-card: #ffffff;
  --bg-soft: #f3f4f6;
  --bg-hover: #eef0f3;
  --border: #e5e7eb;
  --border-strong: #d1d5db;
  --text: #111827;
  --text-sec: #4b5563;
  --text-ter: #9ca3af;
  --brand: #0d99ff;
  --brand-soft: #e6f4ff;
  --ok: #16a34a;
  --ok-soft: #d1fae5;
  --warn: #ca8a04;
  --warn-soft: #fef3c7;
  --err: #dc2626;
  --err-soft: #fee2e2;
  --prefix: #fef3c7; --prefix-b: #d4a017; --prefix-t: #7a5a0d;
  --date:   #d4f7dd; --date-b:   #2e9a3f; --date-t:   #1f5f2a;
  --time:   #d6e8ff; --time-b:   #0d6ec9; --time-t:   #0d4f8f;
  --comma:  #fbd6e7; --comma-b:  #c13d8a; --comma-t:  #8c1656;
  /* Elementos del componente Airing más allá del airing string */
  --icon:     #cffafe; --icon-b:     #06b6d4; --icon-t:     #0e7490; /* Live broadcast (cyan) */
  --rec:      #fee2e2; --rec-b:      #dc2626; --rec-t:      #991b1b; /* Recording dot (rojo) */
  --content:  #f3f4f6; --content-b:  #9ca3af; --content-t:  #1f2937; /* Sibling content text */
  --badge:    #fde68a; --badge-b:    #d97706; --badge-t:    #78350f; /* External badge (Próximamente / U7D) */
  --progress: #d1fae5; --progress-b: #10b981; --progress-t: #065f46; /* Progress bar (live elapsed) */
  --diff:   #fff7e0;

  /* ============ Movistar Brand ============ */
  --m-blue:    #0066FF;
  --m-blue600: #2F7DFF;
  --m-blue300: #80B3FF;
  --m-blue200: #E8F4FA;
  --m-white:   #FEFAF5;
  --m-black:   #262423;
  --m-border-c:#E6E7EB;
  --m-grey-tx: #61636B;
  --m-bg-page:    #F6F7F9;
  --m-bg-alt:     #ffffff;
  --m-bg-brand:   var(--m-blue);
  --m-text-m:     var(--m-black);
  --m-text-m-sec: var(--m-grey-tx);
  --m-border-m:   var(--m-border-c);
  --m-brand:      var(--m-blue);
  --m-on-brand:   #ffffff;
  --m-radius:     12px;
  --m-radius-lg:  20px;
  --m-shadow:     0 1px 2px rgba(38,36,35,.04), 0 8px 20px rgba(38,36,35,.05);
  --m-font: "Telefonica Sans", "On Air", "Poppins", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --m-fs-display: 44px; --m-fs-title1: 32px; --m-fs-title2: 24px; --m-fs-title3: 20px;
  --m-fs-body: 16px; --m-fs-body-s: 14px; --m-fs-caption: 13px;
  --m-lh-tight: 1.15; --m-lh-title: 1.25; --m-lh-body: 1.6;
}
@media (prefers-color-scheme: dark) {
  :root {
    --bg: #0b0e14;
    --bg-card: #161a22;
    --bg-soft: #1f242d;
    --bg-hover: #262c36;
    --border: #2c333d;
    --border-strong: #3d4651;
    --text: #e8eaed;
    --text-sec: #b3b7bf;
    --text-ter: #6b7280;
    --brand: #5cb6ff;
    --brand-soft: rgba(13, 153, 255, 0.12);
    --ok: #4ade80;
    --ok-soft: rgba(74, 222, 128, 0.14);
    --warn: #facc15;
    --warn-soft: rgba(250, 204, 21, 0.14);
    --err: #f87171;
    --err-soft: rgba(248, 113, 113, 0.14);
    --diff: rgba(250, 204, 21, 0.08);
  }
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", Roboto, sans-serif; font-size: 14px; line-height: 1.5; }
/* ============ Chrome general ============ */
html { background: var(--m-bg-page); }
body { margin: 0; font-family: var(--m-font); font-size: var(--m-fs-body); line-height: var(--m-lh-body); color: var(--m-text-m); background: var(--m-bg-page); -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
.container { max-width: 1320px; margin: 0 auto; padding: 0 28px 80px; }

/* Appbar tipo Movistar — banda azul sticky */
.appbar { position: sticky; top: 0; z-index: 50; background: var(--m-bg-brand); color: var(--m-on-brand); display: flex; align-items: center; gap: 12px; padding: 0 28px; height: 52px; }
.appbar .logo { display: inline-flex; align-items: center; gap: 9px; font-weight: 700; font-size: 15px; }
.appbar .logo .xd-logo { color: #fff; }
.appbar .crumb { font-size: 16px; font-weight: 700; letter-spacing: -.01em; }
.appbar .spacer { flex: 1; }
.appbar .meta-pill { font-size: 12px; background: rgba(255,255,255,.16); padding: 4px 10px; border-radius: 999px; display: inline-flex; gap: 6px; align-items: center; color: #fff; }
.appbar .meta-pill .ph { color: #fff; font-size: 14px; }

/* Hero: bloque h1 + descripción bajo el appbar */
.hero { padding: 32px 0 16px; border-bottom: 1px solid var(--m-border-m); margin-bottom: 0; }
.hero h1 { font-size: var(--m-fs-title1); margin: 0 0 8px; letter-spacing: -0.025em; font-weight: 700; line-height: var(--m-lh-tight); color: var(--m-text-m); }
.hero .lede { font-size: 15px; color: var(--m-text-m-sec); line-height: 1.5; max-width: 78ch; margin: 0; font-weight: 400; }

/* Section spacing + h2 numerado */
.block { padding: 28px 0; border-top: 1px solid var(--m-border-m); scroll-margin-top: 72px; }
.block:first-of-type { border-top: none; padding-top: 24px; }
.block > h2 { font-size: var(--m-fs-title3); margin: 0 0 6px; letter-spacing: -.015em; font-weight: 700; line-height: var(--m-lh-title); display: flex; align-items: center; gap: 12px; color: var(--m-text-m); }
.block > h2 .num { display: inline-flex; align-items: center; justify-content: center; min-width: 30px; height: 30px; padding: 0 8px; background: var(--m-brand); color: #fff; border-radius: 999px; font-size: 13px; font-weight: 600; letter-spacing: 0; }
.block > h2 .ph { color: var(--m-text-m-sec); font-size: 20px; }
.block > .desc { color: var(--m-text-m-sec); font-size: 14px; line-height: 1.5; max-width: 78ch; margin: 0 0 16px; }
header.doc-header .meta span { display: inline-flex; align-items: center; gap: 4px; }
nav.toc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 14px 18px; margin-bottom: 32px; display: flex; flex-wrap: wrap; gap: 14px; }
nav.toc a { color: var(--text-sec); text-decoration: none; font-size: 13px; font-weight: 500; display: inline-flex; align-items: center; gap: 4px; }
nav.toc a:hover { color: var(--brand); }
section.block { margin-bottom: 48px; }
section.block > h2 { font-size: 20px; font-weight: 700; margin: 0 0 6px; letter-spacing: -0.005em; display: flex; align-items: center; gap: 8px; }
section.block > h2 .ph { color: var(--text-ter); font-size: 18px; }
section.block > .desc { color: var(--text-sec); font-size: 13.5px; margin-bottom: 18px; }
/* Caja blanca con sombra — estilo del Plugin Design System */
.card { border: 1px solid var(--m-border-m); border-radius: 16px; padding: 22px; background: var(--m-bg-alt); box-shadow: var(--m-shadow); margin-bottom: 14px; transition: box-shadow .15s, transform .15s; }
.card:hover { box-shadow: 0 2px 4px rgba(38,36,35,.05), 0 14px 30px rgba(38,36,35,.08); transform: translateY(-1px); }
.card > h3 { margin: 0 0 6px; font-size: 16px; font-weight: 700; color: var(--m-text-m); display: flex; align-items: center; gap: 10px; }
.card > h3 > .ph:first-child { font-size: 22px; color: var(--m-brand); display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 11px; background: var(--m-bg-tint, var(--m-blue200)); margin-right: 2px; }
.card > .sub { color: var(--m-text-m-sec); font-size: 14px; line-height: 1.55; margin: 0 0 14px; }
.badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; line-height: 1.6; }
.badge .ph { font-size: 11px; }
.badge.ok { background: var(--ok-soft); color: var(--ok); }
.badge.warn { background: var(--warn-soft); color: var(--warn); }
.badge.err { background: var(--err-soft); color: var(--err); }
.badge.info { background: var(--brand-soft); color: var(--brand); }
.badge.neutral { background: var(--bg-soft); color: var(--text-sec); }
table.set { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; }
table.set th, table.set td { padding: 10px 7px; text-align: left; vertical-align: top; border-bottom: 1px solid var(--border); }
table.set th { background: var(--bg-soft); font-weight: 600; font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-sec); }
table.set th:first-child { border-top-left-radius: 8px; }
table.set th:last-child { border-top-right-radius: 8px; }
table.set tbody tr:last-child td { border-bottom: none; }
table.set tbody tr:hover td { background: var(--bg-hover); }
table.set td.level { font-weight: 600; white-space: nowrap; }
table.set td.empty { color: var(--text-ter); font-style: italic; }
table.set td.special { color: var(--brand); font-weight: 500; }
table.set td.disabled { color: var(--text-ter); text-decoration: line-through; }
table.set td.diff { background: var(--diff); }
table.set td.na { color: var(--text-ter); font-style: italic; text-align: center; font-size: 12px; }
table.set td.idem { color: var(--text-ter); text-align: center; font-size: 12px; }
table.set td.idem .ph { color: var(--text-ter); }

/* Multi-row header for grouped matrix */
table.set th.group { text-align: center; border-bottom: 2px solid var(--border-strong); font-size: 11px; }
table.set th.sub { font-size: 10.5px; font-weight: 500; text-transform: none; letter-spacing: 0.02em; }
table.set th.col-estandar { background: rgba(212, 160, 23, 0.08); }
table.set th.col-caption { background: rgba(13, 153, 255, 0.08); }
table.set th.col-grabacion { background: rgba(220, 38, 38, 0.08); }

.matriz-wrapper {
  overflow-x: auto;
  border: 1px solid var(--m-border-m);
  border-radius: 16px;
  background: var(--m-bg-alt);
  box-shadow: var(--m-shadow);
  position: relative;
  max-width: 100%; /* default: respect container */
}
.matriz-wrapper table.set td:not([class*="col-"]):not([class*="set-"]),
.matriz-wrapper table.set th:not([class*="col-"]):not([class*="set-"]) { background: var(--m-bg-alt); }
.matriz-wrapper table.set { border: none; width: max-content; min-width: 100%; }

/* When content exceeds container width, break out to use full viewport (centered) */
.matriz-wrapper.wide {
  max-width: 100vw;
  width: 100vw;
  margin-left: calc(50% - 50vw);
  margin-right: calc(50% - 50vw);
}

/* Sticky Nivel column */
table.set th.col-nivel,
table.set td.col-nivel {
  position: sticky;
  left: 0;
  background: var(--bg-card);
  z-index: 2;
  border-right: 1px solid var(--border);
}
table.set th.col-nivel { background: var(--bg-soft); }
table.set tbody tr:hover td.col-nivel { background: var(--bg-hover); }

/* Column visibility toggles */
.matriz-wrapper[data-show-default="0"] td.col-default,
.matriz-wrapper[data-show-default="0"] th.col-default:not(.group) { display: none; }
.matriz-wrapper[data-show-detail="0"] td.col-detail,
.matriz-wrapper[data-show-detail="0"] th.col-detail:not(.group) { display: none; }
.matriz-wrapper[data-show-sg="0"] td.col-sg,
.matriz-wrapper[data-show-sg="0"] th.col-sg:not(.group) { display: none; }
.matriz-wrapper[data-show-caption="0"] td.col-caption,
.matriz-wrapper[data-show-caption="0"] th.col-caption { display: none; }
.matriz-wrapper[data-show-extended="0"] td.set-est,
.matriz-wrapper[data-show-extended="0"] th.set-est { display: none; }
.matriz-wrapper[data-show-grabacion="0"] td.set-grab,
.matriz-wrapper[data-show-grabacion="0"] th.set-grab { display: none; }

/* If all 3 Airing variants hidden, hide the group headers too */
.matriz-wrapper[data-show-default="0"][data-show-detail="0"][data-show-sg="0"] th.group { display: none; }

/* Matrix controls bar */
.matrix-controls {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 14px 0 10px;
  padding: 10px 14px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  flex-wrap: wrap;
}
.matrix-controls .label {
  font-size: 11.5px;
  color: var(--text-sec);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.toggle-col {
  border: 1px solid transparent;
  background: transparent;
  color: var(--m-text-m-sec);
  padding: 5px 12px;
  border-radius: 999px;
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
  transition: background .12s, color .12s, border-color .12s;
}
.toggle-col:hover { background: var(--m-bg-alt); color: var(--m-text-m); }
.toggle-col.active {
  background: var(--m-bg-alt);
  border-color: var(--m-border-m);
  color: var(--m-text-m);
  font-weight: 600;
  box-shadow: 0 1px 2px rgba(0,0,0,.04);
}

/* Segmented control de modo de vista: agrupar 3 botones contiguos como un único pill */
/* Tabs envolventes — para selectores mono-select (Locale, Vista, Render, Hora) */
.view-mode-group,
.locale-tabs {
  display: inline-flex;
  background: var(--m-bg-page);
  border-radius: 999px;
  padding: 3px;
  gap: 0;
  align-items: center;
}
.view-mode-group .view-mode,
.locale-tabs .locale-tab {
  background: transparent;
  border: 1px solid transparent;
  border-radius: 999px;
  padding: 0 14px;
  height: 28px;
  font-family: inherit;
  font-size: 12px;
  font-weight: 500;
  color: var(--m-text-m-sec);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  white-space: nowrap;
  transition: background .12s, color .12s;
}
.view-mode-group .view-mode .ph { font-size: 13px; }
.view-mode-group .view-mode:hover,
.locale-tabs .locale-tab:hover { color: var(--m-text-m); }
.view-mode-group .view-mode.active,
.locale-tabs .locale-tab.active {
  background: var(--m-bg-alt);
  color: var(--m-text-m);
  font-weight: 600;
  box-shadow: 0 1px 2px rgba(0,0,0,.05);
}

/* Modos de vista: filtran qué se ve en la matriz */
.matriz-wrapper[data-view-mode="airing-comp"] .tk-badge,
.matriz-wrapper[data-view-mode="airing-comp"] .tk-progress,
.matriz-wrapper[data-view-mode="airing-comp"] img.tk-u7d,
.matriz-wrapper[data-view-mode="airing-comp"] span.tk-u7d { display: none !important; }

.matriz-wrapper[data-view-mode="airing-str"] .tk-badge,
.matriz-wrapper[data-view-mode="airing-str"] .tk-progress,
.matriz-wrapper[data-view-mode="airing-str"] .tk-icon,
.matriz-wrapper[data-view-mode="airing-str"] .tk-rec,
.matriz-wrapper[data-view-mode="airing-str"] .tk-content,
.matriz-wrapper[data-view-mode="airing-str"] img.tk-u7d,
.matriz-wrapper[data-view-mode="airing-str"] span.tk-u7d { display: none !important; }
.matriz-wrapper[data-view-mode="airing-str"] .tk-comma:has(+ .tk-content) { display: none !important; }


/* ============ Render Mode: Tokens (default) vs Figma (simulación) ============
   En modo Figma se quitan los colores de los chips, se renderiza como texto plano
   con tipografía sans-serif y se muestra el icono de bolsa de compra en las celdas
   Caption para evaluar el espacio real que ocupa la pill en la UI. */
body[data-render="figma"] .tk {
  background: transparent !important;
  border-color: transparent !important;
  padding: 0 1px !important;
  border-radius: 0 !important;
  font-weight: 500 !important;
  color: var(--text) !important;
}
body[data-render="figma"] .tk-comma { color: inherit !important; padding: 0 !important; margin: 0 !important; }
body[data-render="figma"] .tk-time { font-variant-numeric: tabular-nums; }
body[data-render="figma"] .tk-content { color: var(--text-sec) !important; }
/* tk-u7d / tk-badge / tk-progress mantienen forma de pill — son componentes gráficos.
   Solo aplica al span (fallback). La img ya es un PNG completo, no necesita border/padding/radius. */
body[data-render="figma"] span.tk-u7d { border: 1.5px solid var(--text-sec) !important; color: var(--text) !important; background: transparent !important; padding: 1px 6px !important; font-weight: 700 !important; font-size: 11px !important; border-radius: 5px !important; }
body[data-render="figma"] .tk-badge { background: transparent !important; border: 1.5px solid var(--text-sec) !important; color: var(--text) !important; padding: 1px 6px !important; border-radius: 999px !important; font-weight: 600 !important; }
body[data-render="figma"] .tk-rec { background: transparent !important; border: none !important; padding: 0 !important; }
body[data-render="figma"] .tk-icon { background: transparent !important; border: none !important; padding: 0 !important; color: var(--brand) !important; }
body[data-render="figma"] .tk-progress { background: rgba(16, 185, 129, 0.15) !important; border-color: var(--progress-b) !important; color: var(--text) !important; }
/* Icono bolsa eliminado de las celdas Caption — no forma parte del airing ni del caption (es de la card) */
.figma-buy-icon { display: none !important; }
/* Botón Figma activo */
.render-btn.active[data-render="figma"] { background: rgba(250, 204, 21, 0.18); color: #d97706; font-weight: 600; }

/* ============ Contextos del servicio: cards mockup por nivel temporal ============ */

/* ============ Contextos · ctx-block + device-tabs + ci-* + dp-* ============ */
.ctx-block { margin: 18px 0; padding: 22px; border: 1px solid var(--m-border-m); border-radius: 16px; background: var(--m-bg-alt); box-shadow: var(--m-shadow); }
.ctx-block h3 { font-size: 13px; font-weight: 600; color: var(--m-text-m-sec); margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.04em; display: flex; align-items: center; gap: 6px; }
.ctx-block .sub { font-size: 13px; color: var(--m-text-m-sec); margin: 0 0 14px; line-height: 1.5; }
.device-tabs { display: inline-flex; background: var(--bg-soft); padding: 3px; border-radius: 999px; gap: 2px; margin-bottom: 16px; }
.device-tab { border: none; background: transparent; padding: 6px 16px; border-radius: 999px; font-family: inherit; font-size: 12.5px; font-weight: 500; cursor: pointer; color: var(--text-sec); display: inline-flex; align-items: center; gap: 6px; }
.device-tab .ph { font-size: 14px; }
.device-tab.active { background: var(--bg-card); color: var(--text); font-weight: 600; box-shadow: 0 1px 2px rgba(0,0,0,0.06); }
.device-panel[hidden] { display: none; }
.ctx-grid { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 18px; align-items: start; }
@media (max-width: 860px) { .ctx-grid { grid-template-columns: 1fr; } }
.col-label { font-size: 10.5px; color: var(--m-text-m-sec); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; font-weight: 600; display: flex; align-items: center; gap: 5px; }
.col-label .ph { font-size: 13px; color: var(--m-text-m-sec); }
.ctx-shot { width: 100%; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-soft); aspect-ratio: 16 / 9; position: relative; overflow: hidden; }
.ctx-shot img { position: relative; z-index: 1; width: 100%; height: 100%; object-fit: contain; display: block; }
.ctx-shot .shot-ph { display: none; position: absolute; inset: 0; flex-direction: column; align-items: center; justify-content: center; gap: 8px; background: var(--bg-soft); color: var(--text-ter); font-size: 11px; text-align: center; padding: 14px; }
.ctx-shot .shot-ph .ph { font-size: 26px; opacity: 0.5; }
.ctx-shot .shot-ph code { font-size: 10.5px; background: transparent; color: var(--text-ter); }
.ctx-shot img[data-broken="1"] + .shot-ph { display: flex; }
.ctx-base { border: 1px dashed var(--border-strong); border-radius: 10px; padding: 18px; background: var(--bg); color: var(--text-ter); font-size: 12.5px; min-height: 120px; display: flex; align-items: center; justify-content: center; text-align: center; line-height: 1.5; }
/* Casos · overlay del airing sobre la base limpia (estilo covers) */
.ctx-shot-wide { max-width: 760px; }
.ci-cases { display: flex; gap: 12px; overflow-x: auto; padding: 4px 2px 12px; scrollbar-width: thin; }
.ci-card { flex: 0 0 auto; position: relative; border-radius: 8px; overflow: hidden; border: 1px solid var(--border); background-size: cover; background-position: center; }
.ci-cases-tv .ci-card { width: 440px; aspect-ratio: 844.8 / 626.4; background-image: url('img/mockup-detailsPageTV-base.png'); background-size: 227.27% 172.41%; background-position: 7.143% 52.381%; }
.ci-cases-web .ci-card { width: 440px; aspect-ratio: 417.6 / 360.39; background-image: url('img/mockup-detailsPageWeb-base.png'); background-size: 344.83% 243.90%; background-position: 5.634% 22.034%; }
.ci-card .level-tag { position: absolute; top: 6px; left: 6px; z-index: 2; font-size: 9px; color: rgba(255,255,255,0.95); background: rgba(0,0,0,0.6); text-transform: uppercase; letter-spacing: 0.04em; padding: 2px 7px; border-radius: 999px; font-weight: 600; backdrop-filter: blur(4px); }
.ci-card .ci-airing { position: absolute; left: var(--ax, 25%); top: var(--ay, 70%); transform: translateY(-50%); z-index: 2; text-align: left; font-family: 'Work Sans', -apple-system, sans-serif; font-size: var(--asz, 11px); line-height: 1; white-space: nowrap; display: inline-flex; align-items: center; gap: 4px; }
/* Detail Page · cards portrait, base por estado (CTA distinto) */
.ci-cases-dp { display: flex; gap: 12px; overflow-x: auto; padding: 4px 2px 12px; scrollbar-width: thin; }
.ci-cases-dp .ci-card { width: 300px; aspect-ratio: 360 / 280.7; background-image: var(--base); background-size: 100% auto; background-position: 0% var(--bgy, 81.9%); }
.ci-cases-gr .ci-card { width: 340px; aspect-ratio: 498 / 445; background-image: var(--base); background-size: cover; background-position: center; }
.dp-state { margin-bottom: 6px; }
.dp-state > .col-label { margin-top: 6px; }
/* U7D dentro de .ci-airing: misma imagen que en la tabla canónica */
.ci-airing img.tk-u7d { vertical-align: middle; }
/* i18n de las cards de contexto (sigue el selector Locale, como las cards de Caption) */
.ctx-block .ci-loc { display: none; }
.ctx-block[data-active-locale="es-ES"] .ci-loc[data-locale="es-ES"],
.ctx-block[data-active-locale="es-HISPAM"] .ci-loc[data-locale="es-HISPAM"],
.ctx-block[data-active-locale="pt-BR"] .ci-loc[data-locale="pt-BR"],
.ctx-block[data-active-locale="de-DE"] .ci-loc[data-locale="de-DE"] { display: inline; }
/* Chips dentro de .ci-airing usan el estilo base .tk (mismo que la tabla canónica) — no sobreescribir aquí */
/* Timeline en directo bajo el airing (Detail Page · Directo de la tabla) */
.dp-timeline { display:flex; align-items:center; gap:8px; margin-top:7px; font-size:11px; color:var(--text-sec); font-variant-numeric:tabular-nums; }
.dp-timeline .tl-bar { flex:1; min-width:70px; height:4px; background:var(--border-strong); border-radius:999px; overflow:hidden; }
.dp-timeline .tl-fill { display:block; height:100%; background:var(--brand); border-radius:999px; }

/* ============ Selector HORA: Real (now) / Fija (anchor 25/06/26 15:00) ============
   Cuando Real está activo: aparece reloj pill con dot rojo pulsante; las celdas
   y cards mockup recalculan sus fechas relativo al ahora del navegador. */
.hour-btn .ph-clock-real { color: var(--err); }
.hour-btn.active[data-hour="real"] { background: rgba(220, 38, 38, 0.12); color: var(--err); font-weight: 600; border-color: rgba(220, 38, 38, 0.4); }
.hour-btn.active[data-hour="real"] .ph { color: var(--err); }
.live-clock {
  display: none;
  align-items: center;
  gap: 8px;
  padding: 5px 12px;
  background: var(--bg-card);
  border: 1px solid rgba(220, 38, 38, 0.35);
  border-radius: 999px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  font-size: 12.5px;
  font-weight: 600;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
  margin-left: 8px;
}
body[data-hour="real"] .live-clock { display: inline-flex; }
.live-clock::before {
  content: '';
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--err);
  box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.5);
  animation: lc-pulse 2s infinite;
}
.live-clock .lc-date { color: var(--text-sec); }
.live-clock .lc-time { color: var(--err); }
@keyframes lc-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.5); }
  70%  { box-shadow: 0 0 0 7px rgba(220, 38, 38, 0); }
  100% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0); }
}

/* Cards: ocultar los loc-text que no coinciden con el locale activo */
.caption-context-wrap .loc-text[hidden] { display: none; }
.caption-context-wrap[data-active-locale="es-ES"] .loc-text:not([data-locale="es-ES"]) { display: none; }
.caption-context-wrap[data-active-locale="es-ES"] .loc-text[data-locale="es-ES"] { display: inline-flex; align-items: center; gap: 5px; flex-wrap: nowrap; }
.caption-context-wrap[data-active-locale="pt-BR"] .loc-text:not([data-locale="pt-BR"]) { display: none; }
.caption-context-wrap[data-active-locale="pt-BR"] .loc-text[data-locale="pt-BR"] { display: inline-flex; align-items: center; gap: 5px; flex-wrap: nowrap; }
.caption-context-wrap[data-active-locale="de-DE"] .loc-text:not([data-locale="de-DE"]) { display: none; }
.caption-context-wrap[data-active-locale="de-DE"] .loc-text[data-locale="de-DE"] { display: inline-flex; align-items: center; gap: 5px; flex-wrap: nowrap; }
.caption-context-wrap[data-active-locale="es-419"] .loc-text:not([data-locale="es-HISPAM"]):not([data-locale="es-419"]) { display: none; }
.caption-context-wrap[data-active-locale="es-419"] .loc-text[data-locale="es-HISPAM"],
.caption-context-wrap[data-active-locale="es-419"] .loc-text[data-locale="es-419"] { display: inline-flex; align-items: center; gap: 5px; flex-wrap: nowrap; }

/* ============ Niveles deshabilitados: Pasado +1 año y +7 días no aplican como Emitido en ningún país.
   En Grabación sí aplican (grabaciones pueden ser antiguas). Apagamos solo celdas set-est + Caption. */
table.set tr.row-disabled td.set-est,
table.set tr.row-disabled td.col-caption { opacity: 0.3; pointer-events: none; }
table.set tr.row-disabled td.col-nivel { opacity: 0.6; }
.cap-card[data-level="pasado-1ano"],
.cap-card[data-level="pasado-7d"] { opacity: 0.3; pointer-events: none; }

/* ============ Caption en contexto · cards mockup con cover real ============ */
.caption-context-wrap { margin: 18px 0; padding: 22px; border: 1px solid var(--m-border-m); border-radius: 16px; background: var(--m-bg-alt); box-shadow: var(--m-shadow); }
.caption-context-wrap h3 { font-size: 13px; font-weight: 600; color: var(--m-text-m-sec); margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.04em; display: flex; align-items: center; gap: 6px; }
.caption-context-wrap .sub { font-size: 12px; color: var(--text-ter); margin: 0 0 12px; }
.caption-context-wrap .reference-row { display: flex; align-items: flex-start; gap: 20px; margin-bottom: 14px; padding: 12px; background: var(--bg-soft); border-radius: 10px; border: 1px solid var(--border); }
.caption-context-wrap .reference-row .ref-item { text-align: center; }
.caption-context-wrap .reference-row .ref-item .ref-label { font-size: 10.5px; color: var(--text-ter); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; font-weight: 600; }
.caption-context-wrap .reference-row .ref-img {
  width: 180px;
  aspect-ratio: 2 / 3;
  border-radius: 10px;
  background: var(--bg-card) center/cover no-repeat;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-ter);
  font-size: 10px;
  text-align: center;
  padding: 8px;
  border: 1px dashed var(--border-strong);
}
.caption-context-wrap .reference-row .ref-img[data-loaded="1"] { border-style: solid; }
.caption-context {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding: 4px 2px 14px;
  scrollbar-width: thin;
}
.cap-card {
  flex: 0 0 auto;
  width: 132px;
  position: relative;
  background: transparent;
  /* el border-radius lo lleva la propia imagen — no aplicar aquí para evitar doble redondeo */
}
.cap-card .cover {
  width: 100%;
  aspect-ratio: 2 / 3;
  position: relative;
  background: url('img/mockup-cover-base.png') center/cover no-repeat;
  color: #fff;
}
.cap-card .cover .level-tag {
  position: absolute;
  top: 4px;
  left: 4px;
  font-size: 7px;
  color: rgba(255,255,255,0.95);
  background: rgba(0,0,0,0.55);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 2px 5px;
  border-radius: 999px;
  font-weight: 600;
  backdrop-filter: blur(4px);
}
/* Caption-row absolute en la zona inferior de la imagen.
   Spec Figma reducido al 50% (264→132): padding 0px 25px 7.5px, Work Sans Medium 10/13.
   Conjunto U7D + texto centrado horizontalmente en el espacio entre los paddings. */
.cap-card .caption-row {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8px 7.5px 8px;
  background: transparent;
  color: #fff;
  font-family: 'Work Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 10px;
  font-weight: 500;
  line-height: 13px;
  letter-spacing: 0;
}
.cap-card .caption-row .caption-content { display: inline-flex; align-items: center; gap: 3px; flex-wrap: nowrap; min-width: 0; }
/* Spec Figma reducido al 50%: U7D 17.5×10 px */
.cap-card img.tk-u7d { width: 17.5px; height: 10px; vertical-align: middle; border-radius: 0; padding: 0; background: transparent; flex-shrink: 0; }
/* Timeline visual del componente Live: barra horizontal con avance (sin timestamps — el caption no los lleva).
   Directo: caption-content estirado para que el track ocupe todo el ancho disponible. */
.cap-card[data-level="directo"] .caption-row { justify-content: stretch; }
.cap-card[data-level="directo"] .caption-content { display: flex; width: 100%; flex: 1; }
.cap-card .timeline-mini { display: flex; align-items: center; width: 100%; }
.cap-card .timeline-mini .tl-track { display: block; flex: 1 1 auto; height: 5px; background: #3f3f46; border-radius: 999px; position: relative; overflow: hidden; }
.cap-card .timeline-mini .tl-fill { display: block; height: 100%; width: 65%; background: #22d3ee; border-radius: 999px; }
.cap-card .timeline-mini .tl-time,
.cap-card .timeline-mini .tl-thumb { display: none; }


/* En vista Figma, los tokens del caption se aplanan a texto plano blanco — heredan 20px del caption-row */
body[data-render="figma"] .cap-card .tk { background: transparent !important; border-color: transparent !important; padding: 0 !important; color: #fff !important; font-weight: 500 !important; font-size: inherit !important; }
body[data-render="figma"] .cap-card .tk-comma { color: #fff !important; padding: 0 !important; margin-left: -3px !important; margin-right: 0 !important; }
/* Chips de Content Info / Detail Page / PVR en modo Figma — texto blanco sobre las imágenes oscuras */
body[data-render="figma"] .ci-airing .tk { background: transparent !important; border-color: transparent !important; padding: 0 !important; color: #fff !important; font-weight: 500 !important; }
body[data-render="figma"] .ci-airing .tk-comma { color: #fff !important; padding: 0 !important; margin-left: -3px !important; margin-right: 0 !important; }
body[data-render="figma"] .ci-airing img.tk-u7d { border: none !important; padding: 0 !important; background: transparent !important; border-radius: 0 !important; }
body[data-render="figma"] .ci-airing span.tk-u7d { border: 1.5px solid rgba(255,255,255,0.6) !important; color: #fff !important; background: transparent !important; padding: 1px 6px !important; font-weight: 700 !important; font-size: 11px !important; border-radius: 5px !important; }
body[data-render="figma"] table.set .tk-comma { margin-left: -3px !important; }
/* Solo aplicar el outline-pill al span legacy, NO a la img */
body[data-render="figma"] .cap-card span.tk-u7d { border: 1.5px solid rgba(255,255,255,0.6) !important; color: #fff !important; background: transparent !important; padding: 1px 6px !important; font-weight: 700 !important; font-size: 11px !important; border-radius: 5px !important; }
body[data-render="figma"] .cap-card img.tk-u7d { border: none !important; padding: 0 !important; background: transparent !important; border-radius: 0 !important; }

/* Las cards Live ocultan el icono bolsa porque no son comprables */
.cap-card[data-level="directo"] .figma-buy-icon-card { visibility: hidden; }
/* En modo Tokens dentro de las cards, los chips heredan font-size del caption-row (20px) */
body[data-render="tokens"] .cap-card .caption-row .tk { font-size: inherit; padding: 1px 4px; font-family: inherit; font-weight: 600; line-height: 1; }
body[data-render="tokens"] .cap-card .caption-row span.tk-u7d { font-size: 0.7em; padding: 2px 6px; }

.mobile-airing-toggle.active { background: var(--brand-soft); color: var(--brand); border-color: var(--brand); font-weight: 600; }
.mobile-airing-toggle .ph { font-size: 14px; }



/* Token base — todos los chips (.tk-prefix, .tk-date, .tk-time, .tk-comma, .tk-icon, etc.)
   heredan estas reglas. SIN font-size:0 ni hacks: el padding 3px 2px y el espacio natural
   entre <span> y <span> en el HTML dan la separación visual. */
.tk {
  display: inline-block;
  padding: 3px 2px;
  border: 1.5px solid transparent;
  border-radius: 5px;
  font-weight: 600;
  font-size: 12.5px;
  line-height: 1.3;
  margin: 1px 0;
  vertical-align: baseline;
  white-space: nowrap;
}

.tk-prefix { background: var(--prefix); border-color: var(--prefix-b); color: var(--prefix-t); }
.tk-date   { background: var(--date);   border-color: var(--date-b);   color: var(--date-t); }
.tk-time   { background: var(--time);   border-color: var(--time-b);   color: var(--time-t); }
.tk-comma  { background: var(--comma);  border-color: var(--comma-b);  color: var(--comma-t); padding: 3px 2px; }
/* Elementos del componente Airing más allá del airing string.
   Mismo lenguaje visual (chip con borde) pero con iconos phosphor cuando aplica. */
.tk-icon     { background: var(--icon);     border-color: var(--icon-b);     color: var(--icon-t);     padding: 3px 6px; }
.tk-rec      { background: var(--rec);      border-color: var(--rec-b);      color: var(--rec-t);      padding: 3px 6px; }
.tk-content  { background: var(--content);  border-color: var(--content-b);  color: var(--content-t);  font-weight: 500; }
.tk-badge    { background: var(--badge);    border-color: var(--badge-b);    color: var(--badge-t);    padding: 3px 6px; }
.tk-progress { background: var(--progress); border-color: var(--progress-b); color: var(--progress-t); padding: 3px 6px; font-variant-numeric: tabular-nums; }
/* Badge U7D — img tag con fallback outline si la imagen no carga (el alt="U7D" se muestra). */
img.tk-u7d { display: inline-block; width: 35px; height: 20px; vertical-align: middle; border: none; border-radius: 0; padding: 0; background: transparent; }
/* Outline pill U7D: mismas dimensiones que los demás chips (.tk) para no romper la alineación vertical de la fila */
span.tk-u7d { display: inline-block; padding: 3px 6px; border: 1.5px solid var(--text-sec); border-radius: 5px; font-weight: 700; font-size: 12px; color: var(--text); background: transparent; letter-spacing: 0.04em; vertical-align: baseline; line-height: 1.3; }
.tk-icon .ph, .tk-rec .ph, .tk-badge .ph, .tk-progress .ph { font-size: 12px; vertical-align: -1px; margin-right: 3px; }
.tk-icon .ph:last-child, .tk-rec .ph:last-child, .tk-badge .ph:last-child, .tk-progress .ph:last-child { margin-right: 0; }
/* Mini progress bar inline (visual hint dentro de tk-progress) */
.tk-progress .bar { display: inline-block; width: 32px; height: 4px; background: rgba(16, 185, 129, 0.25); border-radius: 999px; margin-right: 5px; vertical-align: 1px; position: relative; overflow: hidden; }
.tk-progress .bar::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 60%; background: var(--progress-b); border-radius: 999px; }
/* Recording dot animado (sólo donde aparece tk-rec puro) */
.tk-rec .dot { display: inline-block; width: 8px; height: 8px; border-radius: 999px; background: var(--rec-b); margin-right: 4px; vertical-align: 0; }
/* Las celdas dejan el espacio natural entre tokens — sin trampas de font-size:0.
   El padding 3px 2px de .tk ya da separación visual entre chips. */
.tk-spec {
  display: inline-block;
  padding: 3px 8px;
  border: 1.5px dashed var(--brand);
  border-radius: 8px;
  color: var(--brand);
  font-weight: 600;
  font-size: 12.5px;
}
/* Slightly smaller in V2 hint lines · y alineados verticalmente con el texto */
.cite { line-height: 1.9; }
.cite .tk { font-size: 11px; padding: 2px 6px; vertical-align: middle; line-height: 1.4; }
.cite .tk .bar { vertical-align: middle; margin-top: 0; }
/* Cells with line break before cite: el cite va en su propia línea, sin gap extra */
table.set td br + .cite { display: inline-block; margin-top: 4px; }

@media (prefers-color-scheme: dark) {
  .tk-prefix   { background: rgba(212, 160, 23, 0.18);  border-color: #d4a017; color: #f5c542; }
  .tk-date     { background: rgba(46, 154, 63, 0.18);   border-color: #2e9a3f; color: #4ade80; }
  .tk-time     { background: rgba(13, 110, 201, 0.20);  border-color: #0d6ec9; color: #5cb6ff; }
  .tk-comma    { background: rgba(193, 61, 138, 0.20);  border-color: #c13d8a; color: #f472b6; }
  .tk-icon     { background: rgba(6, 182, 212, 0.18);   border-color: #06b6d4; color: #67e8f9; }
  .tk-rec      { background: rgba(220, 38, 38, 0.18);   border-color: #dc2626; color: #fca5a5; }
  .tk-content  { background: rgba(156, 163, 175, 0.14); border-color: #6b7280; color: #e5e7eb; }
  .tk-badge    { background: rgba(217, 119, 6, 0.18);   border-color: #d97706; color: #fcd34d; }
  .tk-progress { background: rgba(16, 185, 129, 0.18);  border-color: #10b981; color: #6ee7b7; }
  .tk-progress .bar { background: rgba(110, 231, 183, 0.25); }
}

/* Variantes de render — tags y tabla */
.variants-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; }
.variants-table th, .variants-table td { padding: 10px 12px; text-align: left; vertical-align: top; border-bottom: 1px solid var(--border); }
.variants-table th { background: var(--bg-soft); font-weight: 600; font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-sec); }
.variants-table th:first-child { border-top-left-radius: 8px; }
.variants-table th:last-child { border-top-right-radius: 8px; }
.variants-table tbody tr:last-child td { border-bottom: none; }
.variants-table td.vname { font-weight: 600; white-space: nowrap; }

.var-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
  line-height: 1.5;
  border: 1px solid transparent;
}
.var-tag .ph { font-size: 10px; }
.var-tag[data-variant="default"]      { background: var(--bg-soft); color: var(--text-sec); border-color: var(--border); }
.var-tag[data-variant="prefix-ext"]   { background: rgba(13, 153, 255, 0.12); color: var(--brand); border-color: rgba(13, 153, 255, 0.45); }
.var-tag[data-variant="trailing-colon"] { background: rgba(193, 61, 138, 0.12); color: #c13d8a; border-color: rgba(193, 61, 138, 0.45); }
.var-tag[data-variant="live-progress"] { background: rgba(46, 154, 63, 0.12); color: var(--ok); border-color: rgba(46, 154, 63, 0.45); }

.case-body .variants { display: flex; gap: 6px; flex-wrap: wrap; margin: 8px 0 4px; }

/* Comment textareas per case + global copy bar */
.case-comment {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px dashed var(--border);
}
.case-comment label {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  font-weight: 600;
  color: var(--text-ter);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 5px;
}
.case-comment label .ph { font-size: 11px; }
.case-comment textarea {
  width: 100%;
  min-height: 52px;
  padding: 8px 10px;
  font-family: inherit;
  font-size: 13px;
  color: var(--text);
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  resize: vertical;
  line-height: 1.45;
  transition: border-color 0.12s, box-shadow 0.12s;
}
.case-comment textarea:focus {
  outline: none;
  border-color: var(--brand);
  box-shadow: 0 0 0 2px var(--brand-soft);
}
.case.has-comment {
  border-left: 3px solid var(--brand);
}

.copy-all-bar {
  position: sticky;
  bottom: 16px;
  margin: 32px 0 0;
  padding: 14px 18px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
  z-index: 10;
}
.copy-all-bar .info {
  font-size: 13px;
  color: var(--text-sec);
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.copy-all-bar .info .ph { color: var(--brand); font-size: 16px; }
.copy-all-bar .info strong { color: var(--text); font-weight: 700; }
.copy-all-bar .actions {
  display: inline-flex;
  align-items: center;
  gap: 10px;
}
.copy-all-bar button {
  background: var(--brand);
  color: white;
  border: none;
  padding: 8px 14px;
  border-radius: 8px;
  font-family: inherit;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.copy-all-bar button:hover { opacity: 0.9; }
.copy-all-bar button:disabled { opacity: 0.4; cursor: not-allowed; }
.copy-all-bar button.ghost {
  background: transparent;
  color: var(--text-sec);
  border: 1px solid var(--border);
}
.copy-all-bar button.ghost:hover { color: var(--err); border-color: var(--err); }
.copy-all-bar .copied-msg {
  color: var(--ok);
  font-size: 12px;
  font-weight: 600;
  opacity: 0;
  transition: opacity 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.copy-all-bar .copied-msg.show { opacity: 1; }
.formula { display: inline-flex; align-items: center; gap: 4px; flex-wrap: wrap; font-family: -apple-system, BlinkMacSystemFont, "Inter", sans-serif; font-size: 13px; line-height: 1.4; }
.tag { display: inline-flex; align-items: center; padding: 2px 6px; border-radius: 5px; font-weight: 600; font-size: 12px; line-height: 1; }
.tag.prefix { background: var(--prefix); border: 1px solid var(--prefix-b); color: var(--prefix-t); }
.tag.date   { background: var(--date);   border: 1px solid var(--date-b);   color: var(--date-t); }
.tag.time   { background: var(--time);   border: 1px solid var(--time-b);   color: var(--time-t); }
.tag.comma  { background: var(--comma);  border: 1px solid var(--comma-b);  color: var(--comma-t); padding: 2px 4px; }
.tag.muted  { background: transparent; border: 1px dashed var(--border-strong); color: var(--text-ter); }
.locale-tabs { margin-bottom: 12px; }
.legend-strip { display: flex; gap: 16px; font-size: 11.5px; color: var(--text-sec); margin: 8px 0 16px; flex-wrap: wrap; }
.legend-strip span { display: inline-flex; align-items: center; gap: 5px; }
.legend-dot { display: inline-block; width: 10px; height: 10px; border-radius: 3px; }
.case-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 900px) { .case-grid { grid-template-columns: 1fr; } }
.case { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.case-img { background: #000; padding: 0; min-height: 60px; max-height: 280px; display: flex; align-items: center; justify-content: center; color: var(--text-ter); font-size: 12px; position: relative; overflow: hidden; }
.case-img img { max-width: 100%; max-height: 280px; height: auto; display: block; }
.case-img .missing { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 20px; text-align: center; color: var(--text-ter); position: absolute; inset: 0; justify-content: center; background: var(--bg-soft); }
.case-img .missing .ph { font-size: 28px; opacity: 0.5; }
.case-img .missing code { font-size: 11px; background: transparent; color: var(--text-ter); }
.case-img img + .missing { display: none; }
.case-img img[data-broken="1"] + .missing { display: flex; }
.case-body { padding: 16px 18px; }
.case-body h4 { margin: 0 0 4px; font-size: 14.5px; font-weight: 600; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.case-body .applies { font-size: 12px; color: var(--text-sec); margin: 8px 0; padding: 6px 10px; background: var(--bg-soft); border-radius: 6px; line-height: 1.5; }
.case-body .applies strong { color: var(--text); font-weight: 600; }
.case-body .note { font-size: 12.5px; color: var(--text-sec); margin-top: 8px; line-height: 1.5; }
.case-body .matches { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
.case-body .diff-line { display: flex; align-items: center; gap: 8px; font-size: 12.5px; padding: 4px 0; flex-wrap: wrap; }
.case-body .diff-line .arrow { color: var(--text-ter); font-weight: 600; }
.case-body code.diff-design { background: var(--err-soft); color: var(--err); padding: 2px 6px; border-radius: 4px; font-weight: 500; font-family: ui-monospace, "SF Mono", Menlo, monospace; }
.case-body code.diff-spec   { background: var(--ok-soft);  color: var(--ok);  padding: 2px 6px; border-radius: 4px; font-weight: 500; font-family: ui-monospace, "SF Mono", Menlo, monospace; }
.case-body code.diff-ok     { background: var(--bg-soft); color: var(--text-sec); padding: 2px 6px; border-radius: 4px; font-weight: 500; font-family: ui-monospace, "SF Mono", Menlo, monospace; }
.color-legend { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 12px 16px; margin: 14px 0 24px; font-size: 12.5px; }
.color-legend strong { display: block; font-size: 13px; margin-bottom: 8px; color: var(--text); }
.color-legend .row { display: flex; gap: 18px; flex-wrap: wrap; color: var(--text-sec); }
.color-legend .row span { display: inline-flex; align-items: center; gap: 6px; }
.color-legend .swatch { display: inline-block; width: 14px; height: 14px; border-radius: 3px; }
.color-legend .swatch.yellow { background: #ffeb3b; }
.color-legend .swatch.green  { background: transparent; border: 2px solid #22c55e; }
.color-legend .swatch.red    { background: transparent; border: 2px solid #ef4444; }

/* Inferred star marker */
table.set sup {
  cursor: help;
  color: var(--warn);
  font-weight: 700;
  font-size: 9px;
  margin-left: 3px;
  vertical-align: super;
}

/* Filter for cases */
code { background: var(--bg-soft); padding: 1px 5px; border-radius: 4px; font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 12px; }
.kbd-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }
.kbd-row .stat { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 12px 16px; min-width: 110px; }
.kbd-row .stat .v { font-size: 22px; font-weight: 700; line-height: 1; }
.kbd-row .stat .l { font-size: 11px; color: var(--text-sec); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px; }
.kbd-row .stat.warn { border-color: var(--warn); border-left: 4px solid var(--warn); }
.kbd-row .stat.err { border-color: var(--err); border-left: 4px solid var(--err); }
.cite { font-size: 11.5px; color: var(--text-ter); font-style: italic; }
hr { border: none; border-top: 1px solid var(--border); margin: 24px 0; }
details summary { cursor: pointer; padding: 8px 0; font-weight: 600; font-size: 13.5px; }
details[open] summary { margin-bottom: 8px; }
.context-list { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 10px; }
@media (max-width: 760px) { .context-list { grid-template-columns: 1fr; } }
.context-pill { font-size: 11.5px; padding: 5px 10px; background: var(--bg-soft); border-radius: 6px; color: var(--text-sec); display: inline-flex; align-items: center; gap: 4px; }
</style>
</head>
<body>

<header class="appbar">
  <span class="logo" aria-label="XD — eXperience Design">
    <svg class="xd-logo" viewBox="0 0 941 612" height="22" fill="currentColor" role="img" aria-label="XD" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 504.586L504.584 0.00241917L609.727 105.145L105.143 609.729L0 504.586Z"/>
      <path d="M635.223 0C804.097 1.47635e-05 940.997 136.9 940.997 305.774C940.997 474.649 804.097 611.549 635.223 611.549C635.036 611.549 634.85 611.548 634.664 611.548V463.344C634.765 463.344 634.866 463.346 634.967 463.346C721.991 463.346 792.539 392.798 792.539 305.773C792.539 218.749 721.991 148.202 634.967 148.202C634.866 148.202 634.765 148.203 634.664 148.203V0.00195312C634.85 0.00162029 635.036 3.01114e-07 635.223 0Z"/>
      <path d="M105.156 0.00195312L609.74 504.585L504.597 609.728L0.0132627 105.145L105.156 0.00195312Z"/>
    </svg>
  </span>
  <span class="crumb">Date format</span>
  <span class="spacer"></span>
  <span class="meta-pill"><i class="ph ph-calendar-blank"></i>2026-06-25</span>
  <span class="meta-pill"><i class="ph ph-user-circle"></i>XD — Entertainment Telefónica</span>
</header>

<div class="container">

<section class="hero">
  <h1>Date format</h1>
  <p class="lede">Composición de fechas en el servicio (TV, Web y Móvil) por nivel temporal, set y locale. Cubre los puntos donde aparece la fecha: el literal <em>airing</em>, el componente Airing, los badges y otros elementos de contexto, y el Caption sobre cover.</p>
</section>

<!-- ===================== MATRIZ CANÓNICA ===================== -->
<section class="block" id="matriz">
  <h2><span class="num">01</span><i class="ph ph-table"></i>Tabla canónica</h2>

  <div class="matrix-controls">
    <span class="label">Locale</span>
    <div class="locale-tabs" role="tablist" style="margin:0">
      <button class="locale-tab active" data-locale="es-ES">ES–M+</button>
      <button class="locale-tab" data-locale="es-419">ES–Hispam</button>
      <button class="locale-tab" data-locale="pt-BR">PT-BR–VIVO</button>
      <button class="locale-tab" data-locale="de-DE">DE–O2</button>
    </div>
    <span style="flex:1"></span>
    <span class="label">Variantes</span>
    <button class="toggle-col active" data-col="default" type="button">Default inline</button>
    <button class="toggle-col" data-col="detail" type="button">Detail Page</button>
    <button class="toggle-col" data-col="sg" type="button">Serie grupo</button>
    <span style="width:8px"></span>
    <span class="label">Sets</span>
    <button class="toggle-col active" data-col="caption" type="button">Caption</button>
    <button class="toggle-col active" data-col="extended" type="button">Airing</button>
    <button class="toggle-col active" data-col="grabacion" type="button">Grabación</button>
  </div>

  <div class="matrix-controls" style="border-radius:10px">
    <span class="label">Vista</span>
    <div class="view-mode-group" role="tablist" aria-label="Modo de vista">
      <button class="view-mode active" data-view="all" type="button" title="Mostrar todos los elementos: lo que compone el plugin + lo que añade el componente Airing + elementos externos (badges, progress en CTA)"><i class="ph ph-stack"></i>Todo</button>
      <button class="view-mode" data-view="airing-comp" type="button" title="Solo elementos dentro del componente Figma 'Airing': icon Live, prefix, date, time, comma, sibling content. Oculta badges externos y progress del CTA."><i class="ph ph-frame-corners"></i>Componente Airing</button>
      <button class="view-mode" data-view="airing-str" type="button" title="Solo el texto compuesto 'airing' que genera el plugin: prefix + date + , + time. Oculta iconos, sibling content y elementos externos."><i class="ph ph-text-aa"></i>Solo string airing</button>
    </div>
    <span style="flex:1"></span>
    <span class="label">Render</span>
    <div class="view-mode-group" role="tablist" aria-label="Modo de render">
      <button class="view-mode render-btn active" data-render="tokens" type="button" title="Cada elemento como chip de color (tk-prefix amarillo, tk-date verde, tk-time azul, tk-comma rosa, etc.) — útil para identificar piezas de composición."><i class="ph ph-list-dashes"></i>Tokens</button>
      <button class="view-mode render-btn" data-render="figma" type="button" title="Simulación visual de la UI real: sin colores de chip, tipografía limpia e icono de bolsa de compra en Caption para evaluar espacio."><i class="ph ph-shopping-bag"></i>Figma</button>
    </div>
    <span style="width:8px"></span>
    <span class="label">Hora</span>
    <div class="view-mode-group" role="tablist" aria-label="Hora">
      <button class="view-mode hour-btn active" data-hour="fixed" type="button" title="Anchor fijo del doc: 25/06/26 15:00. Las fechas son estables y reproducibles para screenshots o reviews."><i class="ph ph-anchor-simple"></i>Fija (25/06/26 15:00)</button>
      <button class="view-mode hour-btn" data-hour="real" type="button" title="Hora real del navegador. Las fechas de la matriz y las cards mockup se recalculan en directo respecto al momento actual."><i class="ph ph-clock-countdown ph-clock-real"></i>Real</button>
    </div>
    <span class="live-clock" id="live-clock" title="Hora del ordenador — las fechas se recalculan en directo"><span class="lc-date"></span><span class="lc-time"></span></span>
  </div>

  <!-- ES -->
  <div class="locale-panel" data-locale="es-ES">
    <div class="matriz-wrapper">
    <table class="set">
      <thead>
        <tr>
          <th rowspan="2" class="col-nivel">Nivel</th>
          <th rowspan="2" class="col-caption">Caption</th>
          <th colspan="3" class="group col-estandar set-est" data-group="estandar">Airing</th>
          <th colspan="3" class="group col-grabacion set-grab" data-group="grabacion">Grabación</th>
        </tr>
        <tr>
          <th class="sub col-estandar col-default set-est">Default inline</th>
          <th class="sub col-estandar col-detail set-est">Detail Page</th>
          <th class="sub col-estandar col-sg set-est">Serie grupo</th>
          <th class="sub col-grabacion col-default set-grab">Default inline</th>
          <th class="sub col-grabacion col-detail set-grab">Detail Page</th>
          <th class="sub col-grabacion col-sg set-grab">Serie grupo</th>
        </tr>
      </thead>
      <tbody>
        <tr class="row-disabled"><td class="level col-nivel">Pasado +1 año</td>
          <td class="col-caption"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">10/12/25</span></td>
          <td class="col-default set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">10/12/25</span></td>
          <td class="col-detail set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">10/12/25</span></td>
          <td class="col-sg set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">10/12/25</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td>
          <td class="col-default set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">10/12/25</span></td>
          <td class="col-detail set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">10/12/25</span></td>
          <td class="col-sg set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">10/12/25</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td></tr>
        <tr class="row-disabled"><td class="level col-nivel">Pasado +7 días</td>
          <td class="col-caption"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">10 dic.</span></td>
          <td class="col-default set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">10 diciembre</span></td>
          <td class="col-detail set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">10 diciembre</span></td>
          <td class="col-sg set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">10 diciembre</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td>
          <td class="col-default set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">10 diciembre</span></td>
          <td class="col-detail set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">10 diciembre</span></td>
          <td class="col-sg set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">10 diciembre</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td></tr>
        <tr><td class="level col-nivel">Pasado 2-7 días</td>
          <td class="col-caption"><span class="tk tk-u7d">U7D</span> <span class="tk tk-date">jue. 10</span></td>
          <td class="col-default set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">jueves</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-detail set-est"><span class="tk tk-u7d">U7D</span> <span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">jueves</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-sg set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">jueves</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td>
          <td class="col-default set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">jueves</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-detail set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">jueves</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-sg set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">jueves</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td></tr>
        <tr><td class="level col-nivel">Pasado Ayer</td>
          <td class="col-caption"><span class="tk tk-u7d">U7D</span> <span class="tk tk-date">ayer</span></td>
          <td class="col-default set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">ayer</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-detail set-est"><span class="tk tk-u7d">U7D</span> <span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">ayer</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-sg set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">ayer</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td>
          <td class="col-default set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">ayer</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-detail set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">ayer</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-sg set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">ayer</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td></tr>
        <tr><td class="level col-nivel">Pasado Hoy</td>
          <td class="col-caption"><span class="tk tk-u7d">U7D</span> <span class="tk tk-date">hoy</span></td>
          <td class="col-default set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">hoy</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-detail set-est"><span class="tk tk-u7d">U7D</span> <span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">hoy</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-sg set-est"><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">hoy</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td>
          <td class="col-default set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">hoy</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-detail set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">hoy</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-sg set-grab"><span class="tk tk-prefix">Grabado</span> <span class="tk tk-date">hoy</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span></td></tr>
        <tr><td class="level col-nivel">Directo</td>
          <td class="col-caption"><span class="tk-spec">[Timeline]</span></td>
          <td class="col-default set-est"><span class="tk tk-prefix">En emisión</span><span class="tk tk-comma">,</span> <span class="tk tk-time">22:00 - 00:50</span></td>
          <td class="col-detail set-est"><span class="tk tk-icon"><i class="ph ph-broadcast"></i></span> <span class="tk tk-prefix">En emisión</span><br><span class="cite">time fuera del string → <span class="tk tk-progress"><span class="bar"></span>00:50/00:50</span> en el CTA</span></td>
          <td class="col-sg set-est"><span class="tk tk-icon"><i class="ph ph-broadcast"></i></span> <span class="tk tk-prefix">En emisión</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span><br><span class="cite">time fuera del string → <span class="tk tk-progress"><span class="bar"></span>00:50/00:50</span> en el CTA</span></td>
          <td class="col-default set-grab"><span class="tk tk-prefix">Grabando</span><span class="tk tk-comma">,</span> <span class="tk tk-time">22:00 - 00:50</span></td>
          <td class="col-detail set-grab"><span class="tk tk-rec"><span class="dot"></span></span> <span class="tk tk-prefix">Grabando</span><br><span class="cite">time fuera del string → <span class="tk tk-progress"><span class="bar"></span>00:50/00:50</span> en el CTA</span></td>
          <td class="col-sg set-grab"><span class="tk tk-rec"><span class="dot"></span></span> <span class="tk tk-prefix">Grabando</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez…</span><br><span class="cite">time fuera del string → <span class="tk tk-progress"><span class="bar"></span>00:50/00:50</span> en el CTA</span></td></tr>
        <tr><td class="level col-nivel">Futuro Hoy</td>
          <td class="col-caption"><span class="tk tk-date">Hoy</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
          <td class="col-default set-est"><span class="tk tk-date">Hoy</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
