<!-- ===================== VARIANTES DE RENDER ===================== -->
<section class="block" id="variantes">
  <h2><span class="num">03</span><i class="ph ph-stack"></i>Variantes de render</h2>
  <p class="desc">Transformaciones que se aplican sobre el airing string según el contexto UI. Son <strong>ortogonales</strong> a los sets canónicos — un mismo set (e.g. Airing) puede renderizarse de varias formas según dónde aparezca.</p>

  <table class="variants-table">
    <thead>
      <tr><th>Variante</th><th>Aplica a</th><th>Transformación sobre el airing string</th><th>Ejemplo</th></tr>
    </thead>
    <tbody>
      <tr>
        <td class="vname"><span class="var-tag" data-variant="default"><i class="ph ph-text-align-left"></i>Default inline</span></td>
        <td>Cards, pills, ContentInfo, captions de cover</td>
        <td>Sin cambios. El airing string es el output completo de la celda canónica.</td>
        <td><span class="tk tk-prefix">Emitido</span> <span class="tk tk-date">ayer</span><span class="tk tk-comma">,</span> <span class="tk tk-time">20:00</span></td>
      </tr>
      <tr>
        <td class="vname"><span class="var-tag" data-variant="prefix-ext"><i class="ph ph-arrow-square-out"></i>Prefix externo</span></td>
        <td>Detail Page · Movie / Serie episodio (zona CTA superior)</td>
        <td>El prefix sale del string — se renderiza como componente <code>tk-badge</code> separado ("Próximamente", "En emisión", "Grabación programada", etc.). El airing string omite el prefix.</td>
        <td><span class="tk tk-badge"><i class="ph ph-clock"></i>Próximamente</span> <span class="tk tk-date">Mañana</span><span class="tk tk-comma">,</span> <span class="tk tk-time">22:00</span></td>
      </tr>
      <tr>
        <td class="vname"><span class="var-tag" data-variant="trailing-colon"><i class="ph ph-text-colon"></i>Trailing colon</span></td>
        <td>Detail Page · Serie grupo (cuando hay episode info sibling)</td>
        <td>Se añade <code>:</code> al final del airing string para introducir el sibling <code>content</code> que va a continuación (T2 Ep12, episodio info, etc.). Confirmado vía Figma: <code>airing="En emisión:"</code>.</td>
        <td><span class="tk tk-prefix">En emisión</span><span class="tk tk-comma">:</span> <span class="tk tk-content">T2 Ep12 Primera vez en Nueva York</span></td>
      </tr>
      <tr>
        <td class="vname"><span class="var-tag" data-variant="live-progress"><i class="ph ph-play-circle"></i>Live · progress</span></td>
        <td>Detail Page · Live (Movie y Serie ep)</td>
        <td>El time range sale del string. La barra de progreso vive <strong>en el CTA Ver / Play</strong> (no en Airing) como elemento hermano del botón. El componente <code>Live</code> (icono <code>((·))</code>) sí aparece a la izquierda como hermano del airing string, dentro del componente Airing.</td>
        <td><span class="tk tk-icon"><i class="ph ph-broadcast"></i></span> <span class="tk tk-prefix">En emisión</span> <span class="cite">+ en el CTA:</span> <span class="tk tk-progress"><span class="bar"></span>00:50 / 00:50</span></td>
      </tr>
    </tbody>
  </table>

  <p class="cite" style="margin-top:14px">Las variantes se combinan: Detail Page · Serie grupo Live aplica <span class="var-tag" data-variant="prefix-ext">Prefix externo</span>, <span class="var-tag" data-variant="trailing-colon">Trailing colon</span> y <span class="var-tag" data-variant="live-progress">Live · progress</span> al mismo tiempo.</p>

  <div class="card" style="margin-top:14px">
    <h3><i class="ph ph-puzzle-piece"></i>Composición completa del componente <code>Airing</code></h3>
    <p class="sub">Lo que el plugin genera es solo una parte. El componente Figma <code>Airing</code> incluye también el icono Live, el sibling de contenido (episodio info) y, externamente, los badges. Mapeo visual de los tokens dentro de Airing:</p>
    <table class="variants-table" style="margin-top:6px">
      <thead><tr><th>Token</th><th>Mapea a</th><th>Cuándo aparece</th></tr></thead>
      <tbody>
        <tr><td><span class="tk tk-prefix">Prefix</span></td><td>Texto <code>airing</code> · parte verbal del string</td><td>Pasado, Live, Futuro (Grab.) — según celda canónica</td></tr>
        <tr><td><span class="tk tk-date">DATE</span></td><td>Texto <code>airing</code> · parte fecha del string</td><td>Casi todos los niveles excepto Live (Extended)</td></tr>
        <tr><td><span class="tk tk-comma">,</span> <span class="tk tk-comma">:</span></td><td>Separador interno del string</td><td>, separa Date y Time · : introduce sibling content</td></tr>
        <tr><td><span class="tk tk-time">Time</span></td><td>Texto <code>airing</code> · hora HH:MM</td><td>Niveles Pasado 2-7d a Hoy-Ayer, Directo, Futuro Hoy-Mñn / 2-7d</td></tr>
        <tr><td><span class="tk tk-icon"><i class="ph ph-broadcast"></i></span></td><td>Componente <code>Live</code> (icono broadcast)</td><td>Solo Directo · Extended (Detail Page / Serie grupo)</td></tr>
        <tr><td><span class="tk tk-rec"><span class="dot"></span>Rec</span></td><td>Componente <code>Recording</code> (dot 🔴)</td><td>Directo · Grabación, también prefix externo Grab. programada</td></tr>
        <tr><td><span class="tk tk-content">T2 Ep12…</span></td><td>Texto sibling <code>content</code> dentro de <code>Airing</code></td><td>Serie grupo · cuando hay episodio info que renderizar a continuación</td></tr>
      </tbody>
    </table>

    <p class="sub" style="margin-top:14px"><strong>Elementos externos al Airing</strong> — viven en otros componentes hermanos, pero impactan en cómo se renderiza el airing string:</p>
    <table class="variants-table" style="margin-top:6px">
      <thead><tr><th>Token</th><th>Vive en</th><th>Cuándo aparece</th></tr></thead>
      <tbody>
        <tr><td><span class="tk tk-badge"><i class="ph ph-clock"></i>Próximamente</span></td><td>Componente badge — hermano del Airing dentro de la card / detail</td><td>Futuro Hoy-Mñn / 2-7d en Detail Page · sustituye al prefix del airing string</td></tr>
        <tr><td><span class="tk tk-badge"><i class="ph ph-arrow-counter-clockwise"></i>U7D</span></td><td>Componente badge — hermano del Airing</td><td><strong>Solo ES (Movistar+).</strong> Pasado Ayer Detail Page · marca el catch-up de los últimos 7 días. O2 y VIVO no usan este badge — su catch-up es por canal (24h, 48h, sin VOD).</td></tr>
        <tr><td><span class="tk tk-progress"><span class="bar"></span>00:50 / 00:50</span></td><td>Componente <code>progress</code> dentro del <strong>CTA Ver / Play</strong> — no del Airing</td><td>Solo Directo · el time range sale del airing string y se muestra como barra elapsed/total bajo el botón</td></tr>
      </tbody>
    </table>
  </div>
</section>




<hr>

</div>

<script>
  // Locale tabs
  function applyLocale(loc) {
    document.body.dataset.locale = loc;
    document.querySelectorAll('.locale-tab').forEach(b => b.classList.toggle('active', b.dataset.locale === loc));
    document.querySelectorAll('.locale-panel').forEach(p => {
      if (p.dataset.locale === loc) p.removeAttribute('hidden');
      else p.setAttribute('hidden', '');
    });
    document.querySelectorAll('.caption-context-wrap').forEach(w => { w.dataset.activeLocale = loc; });
    document.querySelectorAll('.ctx-block').forEach(w => { w.dataset.activeLocale = loc; });
  }

  // Device tabs (toggle TV CORE / Web dentro de ctx-block Content info)
  document.querySelectorAll('.ctx-block .device-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const block = btn.closest('.ctx-block');
      const dev = btn.dataset.device;
      block.dataset.activeDevice = dev;
      block.querySelectorAll('.device-tab').forEach(b => b.classList.toggle('active', b === btn));
      // Mostrar el panel del device seleccionado, ocultar el resto
      block.querySelectorAll('.device-panel').forEach(p => {
        if (p.dataset.device === dev) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    });
  });
  document.querySelectorAll('.locale-tab').forEach(btn => {
    btn.addEventListener('click', () => applyLocale(btn.dataset.locale));
  });
  // Aplicar locale por defecto en el load (ES)
  applyLocale('es-ES');

  // Matrix column visibility toggles
  const MATRIX_TOGGLES_KEY = 'dfh-matrix-toggles-v4';
  const defaultToggles = { default: true, detail: false, sg: false, caption: true, extended: true, grabacion: true };
  let matrixToggles = { ...defaultToggles };
  try {
    const saved = JSON.parse(localStorage.getItem(MATRIX_TOGGLES_KEY) || 'null');
    if (saved && typeof saved.default === 'boolean') {
      matrixToggles = Object.assign({ ...defaultToggles }, saved);
    }
  } catch (e) {}

  function adjustMatrixWidth() {
    document.querySelectorAll('.matriz-wrapper').forEach(wrapper => {
      // Reset to baseline (constrained to container) so we can measure overflow
      wrapper.classList.remove('wide');
      // Force reflow so scrollWidth/clientWidth are fresh
      void wrapper.offsetWidth;
      // If table overflows the wrapper (wrapper has overflow-x: auto), we need full-bleed
      if (wrapper.scrollWidth > wrapper.clientWidth + 1) {
        wrapper.classList.add('wide');
      }
    });
  }
  // Defer initial measurement until layout + fonts are stable
  function scheduleAdjustMatrixWidth() {
    requestAnimationFrame(() => requestAnimationFrame(adjustMatrixWidth));
  }

  function applyMatrixToggles() {
    document.querySelectorAll('.matriz-wrapper').forEach(wrapper => {
      wrapper.dataset.showDefault  = matrixToggles.default   ? '1' : '0';
      wrapper.dataset.showDetail   = matrixToggles.detail    ? '1' : '0';
      wrapper.dataset.showSg       = matrixToggles.sg        ? '1' : '0';
      wrapper.dataset.showCaption  = matrixToggles.caption   ? '1' : '0';
      wrapper.dataset.showExtended = matrixToggles.extended  ? '1' : '0';
      wrapper.dataset.showGrabacion = matrixToggles.grabacion ? '1' : '0';
      const visible = (matrixToggles.default ? 1 : 0) + (matrixToggles.detail ? 1 : 0) + (matrixToggles.sg ? 1 : 0);
      wrapper.querySelectorAll('th[data-group]').forEach(th => {
        if (visible === 0) th.style.display = 'none';
        else { th.style.display = ''; th.colSpan = visible; }
      });
    });
    document.querySelectorAll('.toggle-col').forEach(btn => {
      const k = btn.dataset.col;
      btn.classList.toggle('active', !!matrixToggles[k]);
    });
    localStorage.setItem(MATRIX_TOGGLES_KEY, JSON.stringify(matrixToggles));
    // Re-evaluate width after layout change
    scheduleAdjustMatrixWidth();
  }

  // Adjust on load, resize, and locale switch
  window.addEventListener('resize', scheduleAdjustMatrixWidth);
  window.addEventListener('load', scheduleAdjustMatrixWidth);
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(scheduleAdjustMatrixWidth);
  }
  document.querySelectorAll('.locale-tab').forEach(btn => {
    btn.addEventListener('click', scheduleAdjustMatrixWidth);
  });

  document.querySelectorAll('.toggle-col').forEach(btn => {
    btn.addEventListener('click', () => {
      const k = btn.dataset.col;
      matrixToggles[k] = !matrixToggles[k];
      applyMatrixToggles();
    });
  });

  applyMatrixToggles();

  // ============ Modo de vista: Todo / Componente Airing / Solo string airing ============
  const VIEW_MODE_KEY = 'dfh-view-mode-v1';
  const VIEW_HINTS = {
    'all':         'Mostrando todo: componente Airing + elementos externos (badges, progress en CTA).',
    'airing-comp': 'Mostrando solo elementos dentro del componente Figma Airing. Badges externos y progress del CTA ocultos.',
    'airing-str':  'Mostrando solo el texto compuesto airing que genera el plugin (prefix + date + comma + time).'
  };
  let viewMode = localStorage.getItem(VIEW_MODE_KEY) || 'all';
  if (!VIEW_HINTS[viewMode]) viewMode = 'all';
  function applyViewMode() {
    document.querySelectorAll('.matriz-wrapper').forEach(wrapper => {
      wrapper.dataset.viewMode = viewMode;
    });
    document.querySelectorAll('.view-mode[data-view]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.view === viewMode);
    });
    const hint = document.getElementById('view-mode-hint');
    if (hint) hint.textContent = VIEW_HINTS[viewMode] || '';
    localStorage.setItem(VIEW_MODE_KEY, viewMode);
    scheduleAdjustMatrixWidth();
  }
  document.querySelectorAll('.view-mode[data-view]').forEach(btn => {
    btn.addEventListener('click', () => {
      viewMode = btn.dataset.view;
      applyViewMode();
    });
  });
  applyViewMode();

  // ============ Render Mode: Tokens (default) vs Figma (simulación UI) ============
  const RENDER_KEY = 'dfh-render-mode-v1';
  let renderMode = localStorage.getItem(RENDER_KEY) || 'tokens';
  if (renderMode !== 'tokens' && renderMode !== 'figma') renderMode = 'tokens';

  function applyRenderMode() {
    document.body.dataset.render = renderMode;
    document.querySelectorAll('.render-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.render === renderMode);
    });
    localStorage.setItem(RENDER_KEY, renderMode);
    scheduleAdjustMatrixWidth();
  }
  document.querySelectorAll('.render-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      renderMode = btn.dataset.render;
      applyRenderMode();
    });
  });
  applyRenderMode();

  // ============ Modo HORA: Fija (anchor 25/06/26 15:00) vs Real (now) ============
  // Cuando Real está activo: reloj visible + las celdas tk-date / tk-time se recalculan.
  // Cuando Fija: literales originales del HTML (que se guardan en data-original al cargar).
  const HOUR_KEY = 'dfh-hour-mode-v1';
  // Anchor fijo del doc
  const FIXED_ANCHOR = new Date(2026, 5, 25, 15, 0, 0); // 25 junio 2026 15:00 (mes 0-indexed)
  let hourMode = localStorage.getItem(HOUR_KEY) || 'fixed';
  if (hourMode !== 'fixed' && hourMode !== 'real') hourMode = 'fixed';

  function getAnchor() {
    return hourMode === 'real' ? new Date() : new Date(FIXED_ANCHOR);
  }

  // Diccionarios de localización
  const I18N = {
    months: {
      'es-ES':  ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'],
      'es-419': ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'],
      'pt-BR':  ['janeiro','fevereiro','março','abril','maio','junho','julho','agosto','setembro','outubro','novembro','dezembro'],
      'de-DE':  ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'],
    },
    monthsAbbr: {
      'es-ES':  ['ene.','feb.','mar.','abr.','may.','jun.','jul.','ago.','sep.','oct.','nov.','dic.'],
      'es-419': ['ene.','feb.','mar.','abr.','may.','jun.','jul.','ago.','sep.','oct.','nov.','dic.'],
      'pt-BR':  ['jan.','fev.','mar.','abr.','mai.','jun.','jul.','ago.','set.','out.','nov.','dez.'],
      'de-DE':  ['Jan.','Feb.','Mär.','Apr.','Mai','Jun.','Jul.','Aug.','Sep.','Okt.','Nov.','Dez.'],
    },
    weekdaysLower: {
      'es-ES':  ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'],
      'es-419': ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'],
      'pt-BR':  ['domingo','segunda','terça','quarta','quinta','sexta','sábado'],
      'de-DE':  ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'],
    },
    weekdaysCap: {
      'es-ES':  ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'],
      'es-419': ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'],
      'pt-BR':  ['Domingo','Segunda','Terça','Quarta','Quinta','Sexta','Sábado'],
      'de-DE':  ['Sonntag','Montag','Dienstag','Mittwoch','Donnerstag','Freitag','Samstag'],
    },
    weekdaysAbbrCap: {
      'es-ES':  ['Dom.','Lun.','Mar.','Mié.','Jue.','Vie.','Sáb.'],
      'es-419': ['Dom.','Lun.','Mar.','Mié.','Jue.','Vie.','Sáb.'],
      'pt-BR':  ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'],
      'de-DE':  ['So.','Mo.','Di.','Mi.','Do.','Fr.','Sa.'],
    },
    weekdaysAbbrLower: {
      'es-ES':  ['dom.','lun.','mar.','mié.','jue.','vie.','sáb.'],
      'es-419': ['dom.','lun.','mar.','mié.','jue.','vie.','sáb.'],
      'pt-BR':  ['dom','seg','ter','qua','qui','sex','sáb'],
      'de-DE':  ['so.','mo.','di.','mi.','do.','fr.','sa.'],
    },
    yesterday:  { 'es-ES':'ayer','es-419':'ayer','pt-BR':'ontem','de-DE':'gestern' },
    yesterdayCap: { 'es-ES':'Ayer','es-419':'Ayer','pt-BR':'Ontem','de-DE':'Gestern' },
    today:      { 'es-ES':'hoy','es-419':'hoy','pt-BR':'hoje','de-DE':'heute' },
    todayCap:   { 'es-ES':'Hoy','es-419':'Hoy','pt-BR':'Hoje','de-DE':'Heute' },
    tomorrow:   { 'es-ES':'mañana','es-419':'mañana','pt-BR':'amanhã','de-DE':'morgen' },
    tomorrowCap:{ 'es-ES':'Mañana','es-419':'Mañana','pt-BR':'Amanhã','de-DE':'Morgen' },
  };

  // Calcular fecha-base para cada nivel temporal
  function dateForLevel(level) {
    const now = getAnchor();
    const d = new Date(now);
    switch (level) {
      case 'pasado-1ano':  d.setFullYear(d.getFullYear() - 1); d.setHours(20,0,0,0); break;
      case 'pasado-7d':    d.setDate(d.getDate() - 10);       d.setHours(20,0,0,0); break;
      case 'pasado-2-7d':  d.setDate(d.getDate() - 3);        d.setHours(20,0,0,0); break;
      case 'pasado-ayer':  d.setDate(d.getDate() - 1);        d.setHours(20,0,0,0); break;
      case 'pasado-hoy':   d.setHours(now.getHours()-2 > 0 ? now.getHours()-2 : 10, 0, 0, 0); break;
      case 'directo':      /* now */ break;
      case 'futuro-hoy':   d.setHours(now.getHours()+2 < 23 ? now.getHours()+2 : 20, 0, 0, 0); break;
      case 'futuro-man':   d.setDate(d.getDate() + 1);        d.setHours(20,0,0,0); break;
      case 'futuro-2-7d':  d.setDate(d.getDate() + 3);        d.setHours(20,0,0,0); break;
      case 'futuro-7d':    d.setDate(d.getDate() + 10);       d.setHours(20,0,0,0); break;
    }
    return d;
  }

  function pad(n) { return n < 10 ? '0'+n : ''+n; }
  function formatTime(d) { return pad(d.getHours()) + ':' + pad(d.getMinutes()); }
  function formatDateShort(d, locale) {
    if (locale === 'de-DE') return pad(d.getDate())+'.'+pad(d.getMonth()+1)+'.'+String(d.getFullYear()).slice(-2);
    return pad(d.getDate())+'/'+pad(d.getMonth()+1)+'/'+String(d.getFullYear()).slice(-2);
  }

  // Recálculo de todas las celdas tk-date y tk-time según el modo
  // Guardamos texto original en data-original-text para poder volver atrás
  function snapshotOriginals() {
    document.querySelectorAll('table.set td .tk-date, table.set td .tk-time, .cap-card .caption-row .tk-date, .cap-card .caption-row .tk-time, .cap-card .caption-row .tk-prefix').forEach(el => {
      if (!el.dataset.originalText) el.dataset.originalText = el.textContent;
    });
  }
  function restoreOriginals() {
    document.querySelectorAll('[data-original-text]').forEach(el => {
      el.textContent = el.dataset.originalText;
    });
  }

  // Recalcular todas las celdas date/time para el locale activo
  function recalcAll() {
    const activeLocale = document.querySelector('.locale-tab.active')?.dataset.locale || 'es-ES';
    // Recalcular tk-date dentro de cada fila de la matriz
    document.querySelectorAll('table.set tbody tr').forEach(tr => {
      const levelCell = tr.querySelector('td.col-nivel');
      if (!levelCell) return;
      const levelLabel = levelCell.textContent.trim();
      // Map label → level key
      const map = {
        'Pasado +1 año': 'pasado-1ano', 'Pasado +7 días': 'pasado-7d',
        'Pasado 2-7 días': 'pasado-2-7d', 'Pasado Ayer': 'pasado-ayer',
        'Pasado Hoy': 'pasado-hoy', 'Directo': 'directo',
        'Futuro Hoy': 'futuro-hoy', 'Futuro Mañana': 'futuro-man',
        'Futuro 2-7 días': 'futuro-2-7d', 'Futuro +7 días': 'futuro-7d',
      };
      const level = map[levelLabel];
      if (!level) return;
      const d = dateForLevel(level);
      // Para esta fila, dependiendo del locale, recalcular el contenido de cada .tk-date
      tr.querySelectorAll('.tk-date').forEach(td => {
        const orig = td.dataset.originalText || '';
        td.textContent = computeDateText(orig, level, activeLocale, d);
      });
      // tk-time
      tr.querySelectorAll('.tk-time').forEach(tt => {
        const orig = tt.dataset.originalText || '';
        // Si el original es solo una hora HH:MM, no la cambiamos (es ejemplo del programa). Si fuera dinámico podríamos cambiarla.
        // Por ahora dejamos las horas tal cual. Solo recalculamos texto si es un rango "HH:MM - HH:MM".
        tt.textContent = orig; // sin cambios — las horas de los ejemplos son fijas del programa
      });
    });
    // Cards mockup
    document.querySelectorAll('.cap-card').forEach(card => {
      const level = card.dataset.level;
      const d = dateForLevel(level);
      // tk-date inside the caption-row
      card.querySelectorAll('.caption-row .tk-date').forEach(td => {
        const orig = td.dataset.originalText || '';
        td.textContent = computeDateText(orig, level, activeLocale, d);
      });
      // airing externo: solo texto plano
    });
  }

  // Computa el texto de la fecha en función del original
  // El original nos sirve como "tipo" de formato: si era "10/12/25" → fecha corta; "10 diciembre" → larga; "jueves" → weekday; etc.
  function computeDateText(original, level, locale, d) {
    if (!original) return '';
    const o = original.toLowerCase();
    // Adverbios
    if (['ayer','ontem','gestern'].includes(o)) return I18N.yesterday[locale];
    if (['hoy','hoje','heute'].includes(o)) return I18N.today[locale];
    if (['mañana','amanhã','morgen'].includes(o)) return I18N.tomorrow[locale];
    // Capitalizados (al inicio de string)
    const oc = original;
    if (['Ayer','Ontem','Gestern'].includes(oc)) return I18N.yesterdayCap[locale];
    if (['Hoy','Hoje','Heute'].includes(oc)) return I18N.todayCap[locale];
    if (['Mañana','Amanhã','Morgen'].includes(oc)) return I18N.tomorrowCap[locale];
    // Fecha corta DD/MM/YY o DD.MM.YY
    if (/^\d{1,2}[\/.]\d{1,2}[\/.]\d{2,4}$/.test(original)) return formatDateShort(d, locale);
    // Mes abreviado tipo "10 dic." / "10 dez." / "10. Dez."
    if (/^\d{1,2}\.?\s+\w{2,4}\.$/i.test(original)) {
      const months = I18N.monthsAbbr[locale];
      if (locale === 'de-DE') return d.getDate()+'. '+months[d.getMonth()];
      return d.getDate()+' '+months[d.getMonth()];
    }
    // Mes completo tipo "10 diciembre" / "10. Dezember"
    if (/^\d{1,2}\.?\s+[A-Za-záéíóúäöü]+$/i.test(original)) {
      const months = I18N.months[locale];
      if (locale === 'de-DE') return d.getDate()+'. '+months[d.getMonth()];
      return d.getDate()+' '+months[d.getMonth()];
    }
    // Weekday solo (sin día numérico) — Capitalized o lower
    const isCap = /^[A-ZÄÖÜ]/.test(original);
    const matchWeekdayOnly = original.match(/^[A-Za-záéíóúäöüÄÖÜ]+\.?$/);
    if (matchWeekdayOnly && !original.includes(' ')) {
      const wd = isCap ? I18N.weekdaysCap[locale] : I18N.weekdaysLower[locale];
      return wd[d.getDay()];
    }
    // Weekday con día numérico: "Jueves 10", "jueves 10", "Donnerstag 10"
    const matchWeekdayDay = original.match(/^([A-Za-záéíóúäöüÄÖÜ]+)\.?\s+(\d{1,2})\.?$/);
    if (matchWeekdayDay) {
      const wd = isCap ? I18N.weekdaysCap[locale] : I18N.weekdaysLower[locale];
      if (locale === 'de-DE') return wd[d.getDay()]+' '+d.getDate()+'.';
      return wd[d.getDay()]+' '+d.getDate();
    }
    // Weekday abreviado con día: "Jue. 10", "qui, 10", "Do., 10."
    const matchAbbrComma = original.match(/^([A-Za-záéíóúäöüÄÖÜ]+)\.?,?\s+(\d{1,2})\.?$/);
    if (matchAbbrComma) {
      const wd = isCap ? I18N.weekdaysAbbrCap[locale] : I18N.weekdaysAbbrLower[locale];
      if (locale === 'pt-BR') return wd[d.getDay()]+', '+d.getDate();
      if (locale === 'de-DE') return wd[d.getDay()]+', '+d.getDate()+'.';
      return wd[d.getDay()]+' '+d.getDate();
    }
    return original; // sin cambio si no matcheamos
  }

  // Para el airing externo (texto plano completo)
  function computeAiringText(original, level, locale, d) {
    if (!original) return '';
    // Estrategia: reemplazar pedazos reconocibles del original con sus equivalentes calculados
    let result = original;
    // Replace adverbio capitalized
    ['Ayer','Hoy','Mañana','Ontem','Hoje','Amanhã','Gestern','Heute','Morgen'].forEach(adv => {
      if (result.includes(adv)) {
        const map = { 'Ayer':I18N.yesterdayCap[locale], 'Hoy':I18N.todayCap[locale], 'Mañana':I18N.tomorrowCap[locale],
                       'Ontem':I18N.yesterdayCap[locale], 'Hoje':I18N.todayCap[locale], 'Amanhã':I18N.tomorrowCap[locale],
                       'Gestern':I18N.yesterdayCap[locale], 'Heute':I18N.todayCap[locale], 'Morgen':I18N.tomorrowCap[locale] };
        result = result.replace(adv, map[adv]);
      }
    });
    // Replace adverbio lowercase
    ['ayer','hoy','mañana','ontem','hoje','amanhã','gestern','heute','morgen'].forEach(adv => {
      const re = new RegExp('\\b'+adv+'\\b','g');
      if (re.test(result)) {
        const map = { 'ayer':I18N.yesterday[locale],'hoy':I18N.today[locale],'mañana':I18N.tomorrow[locale],
                       'ontem':I18N.yesterday[locale],'hoje':I18N.today[locale],'amanhã':I18N.tomorrow[locale],
                       'gestern':I18N.yesterday[locale],'heute':I18N.today[locale],'morgen':I18N.tomorrow[locale] };
        result = result.replace(re, map[adv]);
      }
    });
    // Fecha corta
    result = result.replace(/\b\d{1,2}[\/.]\d{1,2}[\/.]\d{2,4}\b/, formatDateShort(d, locale));
    // Mes completo "10 diciembre" / "10. Dezember"
    const monthsLong = I18N.months[locale];
    result = result.replace(/\b\d{1,2}\.?\s+(?:enero|febrero|marzo|abril|mayo|junio|julio|agosto|septiembre|octubre|noviembre|diciembre|janeiro|fevereiro|março|maio|junho|julho|agosto|setembro|outubro|novembro|dezembro|Januar|Februar|März|April|Mai|Juni|Juli|August|September|Oktober|November|Dezember)\b/i,
      locale === 'de-DE' ? d.getDate()+'. '+monthsLong[d.getMonth()] : d.getDate()+' '+monthsLong[d.getMonth()]);
    // Weekday Capitalized + día
    const wdCap = I18N.weekdaysCap[locale];
    result = result.replace(/\b(Jueves|Quinta|Donnerstag)\s+\d{1,2}\b/g,
      locale === 'de-DE' ? wdCap[d.getDay()]+' '+d.getDate() : wdCap[d.getDay()]+' '+d.getDate());
    // Weekday lowercase + día
    const wdLow = I18N.weekdaysLower[locale];
    result = result.replace(/\b(jueves|quinta|donnerstag)\s+\d{1,2}\b/g, wdLow[d.getDay()]+' '+d.getDate());
    return result;
  }

  // Reloj live: actualiza cada segundo cuando Real está activo
  let clockTimer = null;
  function updateClock() {
    const now = new Date();
    const lcDate = document.querySelector('#live-clock .lc-date');
    const lcTime = document.querySelector('#live-clock .lc-time');
    if (lcDate && lcTime) {
      lcDate.textContent = pad(now.getDate())+'/'+pad(now.getMonth()+1)+'/'+String(now.getFullYear()).slice(-2);
      lcTime.textContent = pad(now.getHours())+':'+pad(now.getMinutes())+':'+pad(now.getSeconds());
    }
  }

  function applyHourMode() {
    document.body.dataset.hour = hourMode;
    document.querySelectorAll('.hour-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.hour === hourMode);
    });
    snapshotOriginals();
    if (hourMode === 'real') {
      recalcAll();
      updateClock();
      if (!clockTimer) clockTimer = setInterval(() => { updateClock(); recalcAll(); }, 1000);
    } else {
      restoreOriginals();
      if (clockTimer) { clearInterval(clockTimer); clockTimer = null; }
    }
    localStorage.setItem(HOUR_KEY, hourMode);
  }
  document.querySelectorAll('.hour-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      hourMode = btn.dataset.hour;
      applyHourMode();
    });
  });
  // Re-recalcular cuando cambia el locale
  document.querySelectorAll('.locale-tab').forEach(btn => {
    btn.addEventListener('click', () => { if (hourMode === 'real') recalcAll(); });
  });
  applyHourMode();

</script>

</body>
</html>
